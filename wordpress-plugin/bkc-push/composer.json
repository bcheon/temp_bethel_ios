{
    "name": "bkc/bkc-push",
    "description": "FCM-based push notification WordPress plugin for BKC Church iOS app.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "BKC Church",
            "homepage": "https://bkc.org"
        }
    ],
    "require": {
        "php": "^8.0",
        "woocommerce/action-scheduler": "^3.7",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "classmap": [
            "includes/",
            "admin/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ],
        "exclude-from-classmap": [
            "tests/stubs/"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "audit": {
            "ignore": {
                "PKSA-y2cr-5h3j-g3ys": "Tracked: re-evaluate when firebase/php-jwt publishes a fix; mitigation = our JWTs are short-lived and only used outbound to FCM with our own service account key."
            }
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist"
    }
}
