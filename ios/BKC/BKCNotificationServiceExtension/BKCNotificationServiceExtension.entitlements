<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Group entitlement scaffolded for v1.1 shared device_id read.
         Deferred per spec: NSE reads device_id from App Group in v1.1+. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.org.bkc.churchapp</string>
    </array>
</dict>
</plist>
