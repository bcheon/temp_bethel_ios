# Fastfile — BKC iOS app delivery automation
# Week 6+ skeleton. Expand lanes as CI/CD matures.

default_platform(:ios)

platform :ios do

  desc "Generate Xcode project via XcodeGen"
  lane :setup do
    Dir.chdir("../ios/BKC") do
      sh "xcodegen generate"
    end
  end

  desc "Run unit tests"
  lane :test do
    scan(
      scheme: "BKC",
      project: "ios/BKC/BKC.xcodeproj",
      devices: ["iPhone 15"],
      clean: true,
      output_directory: "fastlane/test_output",
      output_types: "html,junit"
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    # TODO: configure match for code signing (see match lane below)

    # Increment build number from latest TestFlight build
    increment_build_number(
      xcodeproj: "ios/BKC/BKC.xcodeproj"
    )

    gym(
      scheme: "BKC",
      project: "ios/BKC/BKC.xcodeproj",
      export_method: "app-store",
      output_directory: "ios/BKC/build",
      output_name: "BKC.ipa",
      clean: true
    )

    pilot(
      ipa: "ios/BKC/build/BKC.ipa",
      skip_waiting_for_build_processing: true,
      changelog: "Internal beta build"
    )
  end

  # TODO: Add match lane for code signing once certificates are provisioned.
  # Example:
  #   lane :certificates do
  #     match(type: "appstore", app_identifier: "org.bkc.churchapp")
  #     match(type: "appstore", app_identifier: "org.bkc.churchapp.NotificationService")
  #   end

end
